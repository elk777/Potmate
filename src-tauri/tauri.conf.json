{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Potmate",
  "version": "0.1.0",
  "identifier": "com.luckyelk.potmate",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Potmate",
        "width": 220,
        "height": 325,
        "minWidth": 190,
        "minHeight": 250,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "resizable": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "publisher": "Lucky Elk",
    "category": "Lifestyle",
    "shortDescription": "A gentle desktop plant companion.",
    "longDescription": "Potmate turns daily notes and ambient activity into a growing desktop plant companion.",
    "copyright": "Copyright 2026 Lucky Elk",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
